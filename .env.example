# ---- Database ----
DATABASE_URL=""

# ---- Auth (NextAuth v5) ----
AUTH_SECRET=""

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- AI (Google Gemini) ----
# Used by /api/chat and /api/code-completion.
GEMINI_API_KEY=

# ---- Real-time collaboration ----
# Base URL the browser uses to reach the Socket.io server (custom server).
# In development this is usually http://localhost:3000.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- WebRTC TURN (video/audio calls across networks) ----
# Optional. Out of the box, calls use Google STUN + a free public TURN relay,
# which works across most networks. For production reliability, provide your own
# TURN server (e.g. Twilio, Metered, or self-hosted coturn). When set, these
# REPLACE the public relay. Comma-separate multiple URLs.
# NEXT_PUBLIC_TURN_URLS="turn:turn.example.com:3478,turns:turn.example.com:5349"
# NEXT_PUBLIC_TURN_USERNAME=""
# NEXT_PUBLIC_TURN_CREDENTIAL=""
